{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/components/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
